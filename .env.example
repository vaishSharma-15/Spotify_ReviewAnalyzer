# Copy to .env and fill in. All credentials are OPTIONAL — collectors that
# lack their credentials are skipped with a clear message; the rest still run.

# --- Groq (Phase 2 structuring) — https://console.groq.com/keys ---
# Required for Phase 2 (LLM structuring). Get a key, put it in .env (NOT here).
GROQ_API_KEY=
# Optional: override the default model (llama-3.3-70b-versatile)
GROQ_MODEL=

# --- Reddit (https://www.reddit.com/prefs/apps -> create a "script" app) ---
# If unset, the Reddit collector falls back to the public .json endpoints.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-review-analyzer/0.1 by u/yourname

# --- Social media (e.g. X/Twitter API v2 bearer token) ---
# If unset, the social collector is skipped (no public no-auth path).
TWITTER_BEARER_TOKEN=
